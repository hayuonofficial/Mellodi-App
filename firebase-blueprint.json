{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account and status",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "password": { "type": "string" },
        "walletBalance": { "type": "number" },
        "lenPoints": { "type": "number" },
        "tier": { "type": "string", "enum": ["Welcome", "Green", "Gold"] },
        "createdAt": { "type": "string" },
        "biometricEnabled": { "type": "boolean" },
        "biometricToken": { "type": "string" }
      },
      "required": ["id", "name", "email", "phone"]
    },
    "Order": {
      "title": "Order",
      "description": "Purchase order record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "totalPrice": { "type": "number" },
        "currency": { "type": "string" },
        "pointsEarned": { "type": "number" },
        "pointsUsed": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["id", "userId", "items", "totalPrice", "status", "date"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Wallet top-up or points conversion transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["topup", "convert"] },
        "amountVND": { "type": "number" },
        "pointsAmount": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string", "enum": ["success", "pending", "failed"] },
        "date": { "type": "string" }
      },
      "required": ["id", "userId", "type", "amountVND", "status", "date"]
    },
    "RedeemedGift": {
      "title": "RedeemedGift",
      "description": "Gift redeemed with LEN points",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "giftId": { "type": "string" },
        "giftName": { "type": "object" },
        "costPoints": { "type": "number" },
        "redeemedDate": { "type": "string" },
        "claimCode": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "claimed"] },
        "recipientName": { "type": "string" },
        "recipientPhone": { "type": "string" },
        "recipientEmail": { "type": "string" },
        "pickupBranch": { "type": "string" }
      },
      "required": ["id", "userId", "giftId", "giftName", "costPoints", "redeemedDate", "claimCode", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "object" },
        "message": { "type": "object" },
        "type": { "type": "string", "enum": ["order", "wallet", "gift", "system"] },
        "date": { "type": "string" },
        "isRead": { "type": "boolean" }
      },
      "required": ["id", "userId", "title", "message", "type", "date", "isRead"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User records"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Orders submitted by users"
    },
    "transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Wallet transactions"
    },
    "redeemedGifts/{giftId}": {
      "schema": "RedeemedGift",
      "description": "Redeemed gifts history"
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
